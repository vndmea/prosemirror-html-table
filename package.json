{
  "name": "prosemirror-html-table-monorepo",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "license": "MIT",
  "author": "vndmea",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/vndmea/prosemirror-html-table.git"
  },
  "workspaces": [
    "packages/*",
    "examples/*"
  ],
  "scripts": {
    "clean": "rimraf packages/*/dist examples/*/dist coverage docs/site",
    "build": "npm run build:packages",
    "build:packages": "npm run build -w prosemirror-html-table && npm run build -w tiptap-html-table && npm run build -w prosemirror-html-table-s1000d",
    "build:demo:pages": "cross-env GITHUB_PAGES=true npm run build -w vue3-tiptap-table-demo",
    "typecheck": "tsc --noEmit -p tsconfig.json",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:e2e": "playwright test",
    "test:e2e:headed": "playwright test --headed",
    "test:e2e:debug": "playwright test --debug",
    "test:e2e:ui": "playwright test --ui",
    "test:e2e:codegen": "playwright codegen http://127.0.0.1:4173",
    "test:e2e:demo": "npm run test:e2e",
    "test:e2e:demo:headed": "npm run test:e2e:headed",
    "test:e2e:demo:debug": "npm run test:e2e:debug",
    "test:e2e:demo:ui": "npm run test:e2e:ui",
    "playwright:install": "playwright install",
    "playwright:install:with-deps": "playwright install --with-deps",
    "coverage": "vitest run --coverage",
    "lint": "eslint .",
    "pack:core": "npm pack -w prosemirror-html-table --dry-run",
    "pack:tiptap": "npm pack -w tiptap-html-table --dry-run",
    "pack:check": "npm run build:packages && npm run pack:core && npm run pack:tiptap",
    "release:version": "changeset version",
    "release:publish": "npm run build:packages && changeset publish"
  },
  "devDependencies": {
    "@changesets/cli": "^2.31.0",
    "@eslint/js": "^9.0.0",
    "@playwright/test": "^1.54.1",
    "@types/node": "^22.0.0",
    "@vitest/coverage-v8": "^3.0.0",
    "cross-env": "^7.0.0",
    "eslint": "^9.0.0",
    "rimraf": "^6.0.0",
    "start-server-and-test": "^2.0.10",
    "tsup": "^8.0.0",
    "typescript": "^5.0.0",
    "typescript-eslint": "^8.0.0",
    "vitest": "^3.0.0"
  },
  "engines": {
    "node": ">=18"
  }
}
