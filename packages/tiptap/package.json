{
  "name": "tiptap-html-table",
  "version": "0.1.0",
  "description": "Tiptap v3 extensions for full HTML table structures.",
  "type": "module",
  "license": "MIT",
  "author": "vndmea",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/vndmea/prosemirror-html-table.git",
    "directory": "packages/tiptap"
  },
  "homepage": "https://github.com/vndmea/prosemirror-html-table#readme",
  "bugs": {
    "url": "https://github.com/vndmea/prosemirror-html-table/issues"
  },
  "keywords": [
    "tiptap",
    "prosemirror",
    "table",
    "html-table",
    "typescript"
  ],
  "sideEffects": [
    "./dist/styles.css",
    "*.css"
  ],
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    },
    "./styles.css": "./dist/styles.css"
  },
  "scripts": {
    "build": "tsup && node ../../scripts/copy-package-assets.mjs packages/tiptap",
    "typecheck": "tsc --noEmit"
  },
  "peerDependencies": {
    "@tiptap/core": "^3.0.0",
    "prosemirror-html-table": "^0.1.0"
  },
  "devDependencies": {
    "@tiptap/core": "^3.0.0",
    "prosemirror-html-table": "workspace:*"
  },
  "publishConfig": {
    "access": "public",
    "provenance": true
  }
}
